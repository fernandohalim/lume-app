{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lūme",
  "mainBinaryName": "lume",
  "version": "1.0.0",
  "identifier": "com.lume.miniplayer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "lūme",
        "width": 380,
        "height": 132,
        "minWidth": 200,
        "minHeight": 48,
        "maxWidth": 420,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./nsis/hooks.nsh"
      }
    }
  }
}
