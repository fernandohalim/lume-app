# ── lūme configuration ──────────────────────────────────────────
# Rename this file to `lume.env` and place it NEXT TO lume.exe.
# The app reads it at startup — no rebuild needed.

# Your Spotify Client ID.
#  • If the person who gave you lūme added your Spotify account to their app,
#    you can leave the value they shipped as-is and just run + Connect.
#  • Otherwise, create your own app at https://developer.spotify.com/dashboard
#    ("Web API"; redirect URI http://127.0.0.1:8888/callback), add your own
#    Spotify account under User Management, and paste its Client ID here.
LUME_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Optional proxy (corporate networks only). Leave blank on a normal connection.
LUME_HTTP_PROXY=

# Note: you need Spotify Premium, and the Spotify desktop app must be running.
# ────────────────────────────────────────────────────────────────
